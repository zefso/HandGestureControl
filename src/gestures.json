{
  "_comment": "Головний конфіг жестів. Редагуй без перекомпіляції.",
  "gestures": [
    "static",
    "swipe_right",
    "swipe_left",
    "ok",
    "stop",
    "browser",
    "fist_left",
    "swipe_up",
    "swipe_down",
    "call_me"
  ],
  "active_profile": "default",
  "profiles": {
    "default": {
      "description": "Загальний профіль",
      "actions": {
        "swipe_left": {
          "type": "hotkey",
          "keys": ["alt", "tab"],
          "description": "Switch window"
        },
        "swipe_right": {
          "type": "hotkey",
          "keys": ["ctrl", "tab"],
          "description": "Next tab"
        },
        "browser": {
          "type": "url",
          "url": "https://google.com",
          "description": "Open browser"
        },
        "fist_left": {
          "type": "hotkey",
          "keys": ["win", "d"],
          "description": "Show desktop"
        },
        "swipe_up": {
          "type": "hotkey",
          "keys": ["win", "up"],
          "description": "Maximize window"
        },
        "swipe_down": {
          "type": "hotkey",
          "keys": ["win", "down"],
          "description": "Minimize window"
        },
        "call_me": {
          "type": "hotkey",
          "keys": ["alt", "f4"],
          "description": "Close app"
        }
      }
    },
    "browser": {
      "description": "Профіль для браузера",
      "actions": {
        "swipe_left": {
          "type": "hotkey",
          "keys": ["alt", "left"],
          "description": "Back"
        },
        "swipe_right": {
          "type": "hotkey",
          "keys": ["alt", "right"],
          "description": "Forward"
        },
        "browser": {
          "type": "hotkey",
          "keys": ["ctrl", "t"],
          "description": "New tab"
        },
        "fist_left": {
          "type": "hotkey",
          "keys": ["ctrl", "w"],
          "description": "Close tab"
        },
        "swipe_up": {
          "type": "hotkey",
          "keys": ["ctrl", "shift", "t"],
          "description": "Reopen tab"
        },
        "swipe_down": {
          "type": "hotkey",
          "keys": ["ctrl", "w"],
          "description": "Close tab"
        },
        "call_me": {
          "type": "hotkey",
          "keys": ["ctrl", "l"],
          "description": "Focus address bar"
        }
      }
    },
    "media": {
      "description": "Профіль для медіаплеєра",
      "actions": {
        "swipe_left": {
          "type": "key",
          "key": "prevtrack",
          "description": "Previous track"
        },
        "swipe_right": {
          "type": "key",
          "key": "nexttrack",
          "description": "Next track"
        },
        "browser": {
          "type": "key",
          "key": "playpause",
          "description": "Play / Pause"
        },
        "fist_left": {
          "type": "key",
          "key": "volumemute",
          "description": "Mute"
        },
        "swipe_up": {
          "type": "key",
          "key": "volumeup",
          "description": "Volume up"
        },
        "swipe_down": {
          "type": "key",
          "key": "volumedown",
          "description": "Volume down"
        },
        "call_me": {
          "type": "key",
          "key": "playpause",
          "description": "Play / Pause"
        }
      }
    },
    "vscode": {
      "description": "Профіль для VS Code",
      "actions": {
        "swipe_left": {
          "type": "hotkey",
          "keys": ["ctrl", "shift", "tab"],
          "description": "Prev file"
        },
        "swipe_right": {
          "type": "hotkey",
          "keys": ["ctrl", "tab"],
          "description": "Next file"
        },
        "browser": {
          "type": "hotkey",
          "keys": ["ctrl", "shift", "p"],
          "description": "Command palette"
        },
        "fist_left": {
          "type": "hotkey",
          "keys": ["ctrl", "`"],
          "description": "Toggle terminal"
        },
        "swipe_up": {
          "type": "hotkey",
          "keys": ["ctrl", "shift", "k"],
          "description": "Delete line"
        },
        "swipe_down": {
          "type": "hotkey",
          "keys": ["ctrl", "z"],
          "description": "Undo"
        },
        "call_me": {
          "type": "hotkey",
          "keys": ["ctrl", "shift", "`"],
          "description": "New terminal"
        }
      }
    }
  },
  "model": {
    "threshold": 0.92,
    "seq_length": 30,
    "switch_frames": 7,
    "cooldown_frames": 40,
    "swipe_cooldown_frames": 15
  },
  "mouse": {
    "smoothing": 0.3, 
    "click_zone_x": [0.25, 0.75],
    "click_zone_y": [0.25, 0.65]                                                                           
  },
  "volume": {
    "smoothing": 0.15,
    "distance_min": 0.02,
    "distance_max": 0.2
  }
}
